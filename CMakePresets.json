{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 4,
        "minor": 3,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "debug-clang",
            "displayName": "Debug-clang",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/debug",
            "toolchainFile": "${sourceDir}/cmake/clang-toolchain.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug-clang",
            "configurePreset": "debug-clang"
        }
    ]
}